# =============================================================================
#  CELL_MASK.RC
#  Registers the Cell Masking Pipeline module as a left-panel macro button.
# =============================================================================
#
#  PURPOSE :
#     Creates a button "SBF-SEM Cell Mask v2" in the left panel of Amira
#     (just like your old "SBF-SEM Preprocessing" button).
#     Clicking it loads the cell_mask.pyscro module.
#
#  INSTALLATION :
#     Copy to : <Amira>/share/resources/cell_mask.rc
#
#  NOTE :
#     If your Amira installation path is different, update the path below.
# =============================================================================

macroButton -add "SBF-SEM Cell Mask v2" \
            -color "#0E9F6E" \
            -proc {
                load "C:/Program Files/Thermo Scientific Amira-Avizo3D 2025.1/share/python_script_objects/cell_mask.pyscro"
            }
